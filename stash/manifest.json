{
  "manifest_version": 3,
  "name": "Stash",
  "version": "0.2.1",
  "description": "เก็บแท็บทั้งหมดไว้ก่อน กลับมาเปิดทีหลัง — ปุ่มเดียวจบ",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stash — เก็บแท็บทั้งหมด"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
